RELAY_BASE_URL=https://your-relay.example.com/v1
RELAY_API_KEY=replace-with-your-relay-key
AI_MODEL=claude-sonnet-4-6
IMAGE_EDIT_MODEL=gpt-image-2

# Local dev defaults:
# DB_PATH=./data/app.db
# FILE_BASE=./data/files

# Zeabur/production should use persistent Volume paths:
DB_PATH=/volume/app.db
FILE_BASE=/volume/files

# Must be a private random value, 16+ characters. Do not deploy dev-token-change-me.
APP_TOKEN=replace-with-family-app-token

# Optional. Set when generated file URLs need a fixed public origin.
PUBLIC_BASE_URL=

RATE_LIMIT_PER_MINUTE=60
WORKER_COUNT=2
STORAGE_RETENTION_HOURS=24
STORAGE_CLEANUP_INTERVAL_SECONDS=3600
